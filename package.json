{
	"name": "@raygister/mcp",
	"version": "0.1.0",
	"description": "Read-only MCP server for the Raygister API. Lets AI assistants browse architecture consultation projects, lots, specifications, and locations.",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"raygister",
		"architecture",
		"construction",
		"dpgf",
		"claude",
		"anthropic"
	],
	"homepage": "https://github.com/raygister/mcp#readme",
	"bugs": {
		"url": "https://github.com/raygister/mcp/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/raygister/mcp.git"
	},
	"license": "MIT",
	"author": "Raygister",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"raygister-mcp": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"smoke": "tsx scripts/smoke.ts",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.4",
		"posthog-node": "^4.2.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^20.14.0",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.33.0"
}
